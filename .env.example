# ─── x402 Pro Agent — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values

# Your EVM wallet address to receive USDC payments
PAY_TO_ADDRESS=0xYourWalletAddressHere

# Network: testnet = eip155:84532 (Base Sepolia) | mainnet = eip155:8453 (Base)
NETWORK=eip155:84532

# Facilitator: testnet = https://x402.org/facilitator | mainnet = https://api.cdp.coinbase.com/platform/v2/x402
FACILITATOR_URL=https://x402.org/facilitator

# Price per request in USDC (e.g. "0.001" = $0.001)
PRICE_PER_REQUEST=0.001

# CDP API keys — required for mainnet CDP facilitator
# Get these from https://portal.cdp.coinbase.com/
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=

# Server port
PORT=4021

# Agent name shown in discovery metadata
AGENT_NAME=x402 Pro Agent
AGENT_DESCRIPTION=High-security autonomous x402 payment settlement agent with 100% success rate
